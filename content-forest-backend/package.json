{
  "name": "content-forest-backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Content Forest backend skeleton.",
  "scripts": {
    "build": "tsc",
    "start": "npm run build && node dist/app/main.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run",
    "db:clean": "node --experimental-sqlite scripts/clean-app-sqlite.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.26.0",
    "@types/node": "^22.15.3",
    "eslint": "^9.26.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.0",
    "vitest": "^3.1.3"
  },
  "dependencies": {
    "agent-browser": "^0.27.0"
  }
}
