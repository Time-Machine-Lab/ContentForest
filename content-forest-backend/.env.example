CONTENT_FOREST_CONTENT_ROOT=data/content
CONTENT_FOREST_DATABASE_PATH=data/app.sqlite
CONTENT_FOREST_PORT=3001

CONTENT_FOREST_AGENT_LLM_MODE=fake
CONTENT_FOREST_AGENT_LLM_PROVIDER=minimax
CONTENT_FOREST_AGENT_LLM_BASE_URL=https://api.minimaxi.com/v1
CONTENT_FOREST_AGENT_LLM_MODEL=your-model-name
CONTENT_FOREST_AGENT_LLM_API_KEY=your-api-key-here

CONTENT_FOREST_AGENT_EXCHANGE_LOG_ENABLED=false
CONTENT_FOREST_AGENT_EXCHANGE_LOG_DIR=logs
CONTENT_FOREST_AGENT_EXCHANGE_LOG_MAX_CONTENT_CHARS=4000

CONTENT_FOREST_RESEARCH_PROVIDER=codex-external-agent
CONTENT_FOREST_RESEARCH_FALLBACK_PROVIDER=

CONTENT_FOREST_TIKHUB_MCP_ENABLED=true
CONTENT_FOREST_TIKHUB_MCP_BASE_URL=https://mcp.tikhub.io
CONTENT_FOREST_TIKHUB_MCP_API_KEY=your-tikhub-api-key-here
CONTENT_FOREST_TIKHUB_MCP_ENABLE_ALL_PLATFORMS=true
CONTENT_FOREST_TIKHUB_MCP_ENABLED_PLATFORMS=
CONTENT_FOREST_TIKHUB_MCP_EXCLUDED_PLATFORMS=xiaohongshu,xhs,rednote
CONTENT_FOREST_TIKHUB_MCP_TIMEOUT_MS=60000
CONTENT_FOREST_TIKHUB_MCP_MAX_RESULTS=8

CONTENT_FOREST_CODEX_RESEARCH_BASE_URL=http://your-codex-provider.example/v1
CONTENT_FOREST_CODEX_RESEARCH_API_KEY=your-codex-provider-api-key-here
CONTENT_FOREST_CODEX_RESEARCH_WIRE_API=responses
CONTENT_FOREST_CODEX_RESEARCH_MODEL=gpt-5.5
CONTENT_FOREST_CODEX_RESEARCH_REASONING_EFFORT=low
CONTENT_FOREST_CODEX_RESEARCH_AUTH_METHOD=api
CONTENT_FOREST_CODEX_RESEARCH_WEB_SEARCH_ENABLED=true
CONTENT_FOREST_CODEX_RESEARCH_SEARCH_CONTEXT_SIZE=medium
CONTENT_FOREST_CODEX_RESEARCH_TIMEOUT_MS=180000
CONTENT_FOREST_CODEX_RESEARCH_MAX_OUTPUT_TOKENS=6000

CONTENT_FOREST_XIAOHONGSHU_CLI_ENABLED=true
CONTENT_FOREST_XIAOHONGSHU_CLI_PATH=xhs
CONTENT_FOREST_XIAOHONGSHU_CLI_TIMEOUT_MS=60000
CONTENT_FOREST_XIAOHONGSHU_CLI_MAX_RESULTS=8
CONTENT_FOREST_XIAOHONGSHU_CLI_DEFAULT_SORT=general
CONTENT_FOREST_XIAOHONGSHU_CLI_CHECK_LOGIN=true
